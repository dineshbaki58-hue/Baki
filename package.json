{
  "name": "bakifitness-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/server",
    "build": "npm run build -w packages/shared && npm run build -w apps/server",
    "prisma:generate": "npm run generate -w apps/server",
    "prisma:migrate": "npm run migrate -w apps/server",
    "seed": "npm run seed -w apps/server"
  }
}
