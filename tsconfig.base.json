{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@baki/shared": ["packages/shared/src"]
    }
  }
}
