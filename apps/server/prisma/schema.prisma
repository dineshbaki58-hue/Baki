generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  heightCm      Int?
  weightKg      Float?
  goal          String?
  stripeCustomerId String?
  subscriptions Subscription[]
  progressEntries Progress[]
}

model Subscription {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  status       String
  currentPeriodEnd DateTime?
  priceId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkoutVideo {
  id          String   @id @default(cuid())
  title       String
  description String
  durationSec Int
  level       String
  muscleGroup String
  videoUrl    String
  thumbnailUrl String
  createdAt   DateTime @default(now())
}

model Progress {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  date        DateTime
  weightKg    Float?
  calories    Int?
  proteinG    Int?
  carbsG      Int?
  fatsG       Int?
  notes       String?
  createdAt   DateTime @default(now())
  @@unique([userId, date])
}

enum Role {
  USER
  ADMIN
}
